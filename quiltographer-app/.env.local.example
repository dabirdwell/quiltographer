# ============================================================
# Quiltographer — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# ---------- App ----------
# Public URL of the deployed app (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Stripe (payments) ----------
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Publishable key (client-side, safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Price ID for the Pro subscription product
STRIPE_PRO_PRICE_ID=price_...

# Webhook signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------- AI: Clarifications (Claude) ----------
# Powers the "Explain this step" feature
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ---------- AI: Comprehension pipeline (optional) ----------
# Gemini — used for extraction of scanned/image-heavy PDFs
# https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# OpenAI — used for pattern comprehension (gpt-4o-mini)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ---------- AI: Self-hosted OCR (optional) ----------
# Only needed if you run your own OCR models
# HUNYUAN_API_URL=http://localhost:8000/v1
# DEEPSEEK_OCR_URL=
# PADDLEOCR_URL=
